# ── Adzuna Jobs API (required) ────────────────────────────────────────────────
# Free tier at https://developer.adzuna.com/
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# ── OpenAI (optional — enables GPT-powered job matching) ──────────────────────
# Get key at https://platform.openai.com/api-keys
# If not set, falls back to free keyword-based matching
OPENAI_API_KEY=your_openai_api_key

# ── Gmail SMTP (required — sends the job digest email) ────────────────────────
# Use a Gmail App Password (NOT your account password)
# Enable at: Google Account → Security → 2-Step Verification → App Passwords
GMAIL_EMAIL=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# ── Matching settings (optional) ──────────────────────────────────────────────
USE_GPT_MATCHING=true          # true = GPT matching, false = free keyword matching
MATCH_SCORE_THRESHOLD=30       # Minimum match % to include a job (0–100)
TOP_JOBS_COUNT=10              # Max jobs included in each digest email
